# OpenAI-compatible text/multimodal endpoint used by the SearchGen reasoner.
SEARCHGEN_CHAT_BASE_URL=https://api.example.com/v1
SEARCHGEN_CHAT_API_FORMAT=openai
SEARCHGEN_CHAT_API_KEY=

# Required only when S1 decides that web/image search is needed.
SEARCHGEN_SEARCH_API_URL=https://search.example.com/v1
SEARCHGEN_SEARCH_SIGNER=my_project.signers:sign_search_request

# User-owned signer settings belong in the user's environment or secret manager.
MY_SEARCH_API_KEY=
